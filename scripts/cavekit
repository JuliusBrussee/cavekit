#!/usr/bin/env bash
# Thin compatibility shim that forwards to the Go CLI.

set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"

  while [[ -L "$source" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="${dir}/${source}"
  done

  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if command -v cavekit >/dev/null 2>&1; then
  BIN_PATH="$(command -v cavekit)"
  if [[ "$BIN_PATH" != "$0" ]]; then
    exec "$BIN_PATH" "$@"
  fi
fi

command -v go >/dev/null 2>&1 || {
  echo "go not found." >&2
  exit 1
}

cd "$ROOT_DIR"
exec go run ./cmd/cavekit "$@"
